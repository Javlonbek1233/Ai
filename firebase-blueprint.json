{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Premium user account data and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatThread": {
      "title": "AI Conversation",
      "description": "Stored AI chat history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "AnalyticsEvent": {
      "title": "System Event",
      "description": "Log of user actions for analytics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Standard user document"
    },
    "/chats/{chatId}": {
      "schema": "ChatThread",
      "description": "AI conversation thread"
    },
    "/analytics/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Privacy-safe event logs"
    }
  }
}
